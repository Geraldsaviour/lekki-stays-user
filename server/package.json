{
  "name": "lekkistays-backend",
  "version": "1.0.0",
  "description": "Backend server for Lekki Stays luxury shortlet booking platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate": "node migrate-to-firebase.js",
    "test:firebase": "node test-firebase.js",
    "test": "node final-test.js",
    "test:performance": "node test-performance.js",
    "test:load": "node load-test.js --suite",
    "test:load:light": "node load-test.js --duration 15 --rps 2",
    "test:load:heavy": "node load-test.js --duration 20 --rps 10",
    "test:bookings": "node load-test.js --duration 15 --rps 3 --endpoint /api/bookings",
    "test:final": "node final-test.js",
    "monitor": "node monitor-system.js --monitor",
    "health": "node monitor-system.js --check"
  },
  "keywords": [
    "booking",
    "shortlet",
    "luxury",
    "nigeria",
    "whatsapp"
  ],
  "author": "Lekki Stays",
  "license": "ISC",
  "dependencies": {
    "@supabase/supabase-js": "^2.105.1",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.4.1",
    "firebase": "^12.12.1",
    "firebase-admin": "^13.8.0",
    "validator": "^13.15.35",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "axios": "^1.15.2",
    "nodemon": "^3.0.2"
  }
}
