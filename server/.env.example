# Lekki Stays / LuxStay Backend Environment Variables

# ============================================================================
# SUPABASE CONFIGURATION (Required)
# ============================================================================
# Get these from your Supabase project settings:
# https://app.supabase.com/project/_/settings/api

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================================================
# WHATSAPP CONFIGURATION (Required)
# ============================================================================
# Host WhatsApp number for booking notifications
# Format: +234XXXXXXXXXX (include country code)

HOST_WHATSAPP_NUMBER=+2349039269846

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

# Server port (default: 3000)
PORT=3000

# Node environment (development, production, test)
NODE_ENV=production

# Base URL for the application (used in WhatsApp messages and links)
BASE_URL=https://your-domain.com

# ============================================================================
# OPTIONAL CONFIGURATION
# ============================================================================

# Rate limiting (requests per window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=5

# Session secret (for future authentication features)
# SESSION_SECRET=your-random-secret-here

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================
#
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Create a Supabase project:
#    - Go to https://app.supabase.com
#    - Create a new project
#    - Wait for database to be ready
#
# 3. Run the database schema:
#    - Open Supabase SQL Editor
#    - Copy contents of supabase/schema.sql
#    - Execute the SQL
#
# 4. Get your Supabase credentials:
#    - Go to Project Settings > API
#    - Copy Project URL → SUPABASE_URL
#    - Copy anon/public key → SUPABASE_ANON_KEY
#    - Copy service_role key → SUPABASE_SERVICE_ROLE_KEY
#
# 5. Update WhatsApp number:
#    - Set HOST_WHATSAPP_NUMBER to your business WhatsApp
#
# 6. Update BASE_URL:
#    - Set to your production domain
#    - For local dev: http://localhost:3000
#
# 7. Install dependencies:
#    npm install
#
# 8. Start the server:
#    npm start (production)
#    npm run dev (development with auto-reload)
#
# ============================================================================
# SECURITY NOTES
# ============================================================================
#
# - NEVER commit .env to version control
# - Keep SUPABASE_SERVICE_ROLE_KEY secret (bypasses RLS)
# - SUPABASE_ANON_KEY is safe to expose in frontend
# - Rotate keys if compromised
# - Use different keys for dev/staging/production
#
# ============================================================================
